# Generated By: Claude Code (Claude Opus 4.7 (1M context))
FROM python:3.14-slim AS build

WORKDIR /build
COPY pyproject.toml README.md LICENSE MANIFEST.in /build/
COPY src /build/src
RUN pip install --no-cache-dir --upgrade pip build && \
    python -m build --wheel --outdir /dist

FROM python:3.14-slim

LABEL org.opencontainers.image.title="claude-quota-exporter"
LABEL org.opencontainers.image.description="Prometheus exporter for Anthropic Claude OAuth API usage limits"
LABEL org.opencontainers.image.licenses="Apache-2.0"
LABEL org.opencontainers.image.source="https://github.com/jewzaam/claude-quota-exporter"

RUN useradd --create-home --uid 10001 exporter
USER exporter
WORKDIR /home/exporter

COPY --from=build --chown=exporter:exporter /dist/*.whl /tmp/
RUN pip install --no-cache-dir --user /tmp/*.whl && rm -f /tmp/*.whl
ENV PATH="/home/exporter/.local/bin:${PATH}"

EXPOSE 9180

ENTRYPOINT ["claude-quota-exporter"]
CMD ["--config", "/etc/claude-quota-exporter/config.json"]
